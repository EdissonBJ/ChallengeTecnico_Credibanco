# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

set -e

MAVEN_WRAPPER_PROPERTIES="$(dirname "$0")/.mvn/wrapper/maven-wrapper.properties"

DISTRIBUTION_URL=$(grep "distributionUrl" "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')

MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_HOME="$MAVEN_USER_HOME/wrapper/dists"

MAVEN_DIST_NAME=$(basename "$DISTRIBUTION_URL" .zip)
MAVEN_DIST_DIR="$MAVEN_HOME/$MAVEN_DIST_NAME"
MAVEN_BIN="$MAVEN_DIST_DIR/bin/mvn"

if [ -f "$MAVEN_BIN" ]; then
  exec "$MAVEN_BIN" "$@"
fi

echo "Downloading Maven from $DISTRIBUTION_URL ..."
mkdir -p "$MAVEN_DIST_DIR"

if command -v curl > /dev/null 2>&1; then
  curl -fsSL "$DISTRIBUTION_URL" -o "$MAVEN_DIST_DIR/maven.zip"
elif command -v wget > /dev/null 2>&1; then
  wget -q "$DISTRIBUTION_URL" -O "$MAVEN_DIST_DIR/maven.zip"
else
  echo "ERROR: Neither curl nor wget is available." >&2
  exit 1
fi

unzip -q "$MAVEN_DIST_DIR/maven.zip" -d "$MAVEN_HOME"
rm "$MAVEN_DIST_DIR/maven.zip"

# The zip extracts as apache-maven-X.X.X inside MAVEN_HOME
EXTRACTED=$(find "$MAVEN_HOME" -maxdepth 1 -name "apache-maven-*" -type d | head -1)
if [ "$EXTRACTED" != "$MAVEN_DIST_DIR" ]; then
  mv "$EXTRACTED" "$MAVEN_DIST_DIR"
fi

chmod +x "$MAVEN_BIN"
exec "$MAVEN_BIN" "$@"
